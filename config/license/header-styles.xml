<!--
  ~ Custom header definitions for the Pathling codebase.
  ~
  ~ SCRIPT_STYLE_2SP: hash-prefixed headers with two spaces of padding,
  ~ matching the convention used in the Python and R sources.
  ~
  ~ SLASHSTAR_STYLE_BLANK_END: C-style block comment that includes a blank
  ~ comment line before the closing delimiter, matching the Bunsen-derived
  ~ convention used throughout the encoders module.
  -->
<additionalHeaders>
    <script_style_2sp>
        <firstLine>EOL</firstLine>
        <beforeEachLine>#  </beforeEachLine>
        <endLine>EOL</endLine>
        <skipLinePattern>^#!.*$</skipLinePattern>
        <firstLineDetectionPattern>^#.*$</firstLineDetectionPattern>
        <lastLineDetectionPattern>^#.*$</lastLineDetectionPattern>
        <allowBlankLines>true</allowBlankLines>
        <isMultiline>true</isMultiline>
        <padLines>true</padLines>
    </script_style_2sp>
    <slashstar_style_blank_end>
        <firstLine>/*</firstLine>
        <beforeEachLine> * </beforeEachLine>
        <endLine> *&#10; */</endLine>
        <firstLineDetectionPattern>(\s|\t)*/\*.*$</firstLineDetectionPattern>
        <lastLineDetectionPattern>.*\*/(\s|\t)*$</lastLineDetectionPattern>
        <allowBlankLines>false</allowBlankLines>
        <isMultiline>true</isMultiline>
        <padLines>false</padLines>
    </slashstar_style_blank_end>
</additionalHeaders>
